  "bugs": {
    "url": "https://github.com/lucas-oitaven/burger-queen-ai-assistant/issues"
  },
  "homepage": "https://github.com/lucas-oitaven/burger-queen-ai-assistant#readme",
  "dependencies": {
    "@langchain/community": "^1.1.28",
    "@langchain/core": "^1.1.47",
    "@langchain/openai": "^1.4.6",
    "better-sqlite3": "^12.10.0",
    "chromadb": "^3.4.3",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "langchain": "^1.4.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "vitest": "^4.1.6"
  }
